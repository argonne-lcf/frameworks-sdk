#!/usr/bin/env bash

source "$(dirname "$(realpath "${BASH_SOURCE[0]}")")/../ci-lib.sh"

# 1) Pull source and gen build environment
gen_build_dir_with_git 'https://github.com/pytorch/vision'
setup_build_env

artifact_in "torch-*.whl"
setup_uv_venv -r pyproject.toml *.whl

# 2) Build & Archive
build_bdist_wheel
artifact_out "torchvision-*.whl"
